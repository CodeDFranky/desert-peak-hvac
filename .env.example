# Sanity — create a project at https://sanity.io, then fill these in and copy to .env
# Server-side (build-time queries)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production

# Client-side (embedded Studio at /studio) — must be prefixed with PUBLIC_
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production

# Write token for `npm run seed` only (sanity.io -> API -> Tokens -> Editor role).
# Never commit this. Not needed for the site build.
SANITY_API_WRITE_TOKEN=

# Web3Forms access key for the contact form (free key at https://web3forms.com).
# Public by design, safe to commit.
PUBLIC_WEB3FORMS_KEY=
