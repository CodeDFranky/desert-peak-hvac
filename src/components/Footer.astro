---
import { Icon } from 'astro-icon/components';
import { telHref } from '../lib/format';
import type { SiteSettings } from '../lib/sanity';

interface Props {
  settings: SiteSettings;
}
const { settings } = Astro.props;

const links = [
  { label: 'Services', href: '#services' },
  { label: 'Service Area', href: '#service-area' },
  { label: 'Reviews', href: '#reviews' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="bg-brand-navy text-brand-white">
  <div class="mx-auto max-w-content px-6 py-16">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1.5fr]">
      <div>
        <div class="flex items-center gap-2">
          <Icon name="ph:mountains-fill" class="h-6 w-6 text-brand-red" aria-hidden="true" />
          <span class="text-lg font-extrabold tracking-tight">Desert Peak</span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-brand-white/70">
          Licensed heating and cooling service across Henderson and the Las Vegas Valley since
          2009.
        </p>
      </div>

      <nav aria-label="Footer">
        <ul class="flex flex-col gap-3">
          {
            links.map((l) => (
              <li>
                <a href={l.href} class="text-sm font-semibold text-brand-white/80 hover:text-brand-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="flex flex-col gap-3 text-sm text-brand-white/80">
        <a href={telHref(settings.phone)} class="font-semibold hover:text-brand-white">
          {settings.phone}
        </a>
        <a href={`mailto:${settings.email}`} class="hover:text-brand-white">{settings.email}</a>
        <p class="text-brand-white/70">{settings.address}</p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-brand-white/15 pt-6 text-sm text-brand-white/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; 2026 Desert Peak Heating &amp; Cooling</p>
      <p>Nevada licensed HVAC contractor, NSCB #0089421</p>
    </div>
  </div>
</footer>
