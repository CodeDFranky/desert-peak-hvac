---
import { Icon } from 'astro-icon/components';
import { telHref } from '../lib/format';

interface Props {
  phone: string;
}
const { phone } = Astro.props;

const neighborhoods = [
  'Henderson',
  'Green Valley',
  'Anthem',
  'Las Vegas',
  'Summerlin',
  'Boulder City',
  'North Las Vegas',
  'Enterprise',
  'Spring Valley',
];
---

<section id="service-area" class="scroll-mt-16 bg-mist">
  <div class="mx-auto max-w-content px-6 py-20 md:py-28">
    <div class="max-w-2xl" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        Serving Henderson and the greater Las Vegas area
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-steel">
        Fast, local response throughout the valley. If you are nearby, we can help.
      </p>
    </div>

    <ul class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3" data-reveal>
      {
        neighborhoods.map((name) => (
          <li class="flex items-center gap-2.5 rounded-sm border border-hairline bg-brand-white px-4 py-3.5 text-sm font-semibold text-brand-navy">
            <Icon name="ph:map-pin-fill" class="h-4 w-4 shrink-0 text-brand-red" aria-hidden="true" />
            {name}
          </li>
        ))
      }
    </ul>

    <p class="mt-8 text-base text-steel">
      Not sure you are in our service area?{' '}
      <a href={telHref(phone)} class="font-semibold text-brand-red hover:text-red-deep">
        Call {phone}
      </a>{' '}
      and we will let you know right away.
    </p>
  </div>
</section>
