---
import { Icon } from 'astro-icon/components';
import { telHref } from '../lib/format';
import type { Service, SiteSettings } from '../lib/sanity';

interface Props {
  settings: SiteSettings;
  services: Service[];
}
const { settings, services } = Astro.props;
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;

const details = [
  { icon: 'ph:phone-fill', label: 'Phone', value: settings.phone, href: telHref(settings.phone) },
  { icon: 'ph:envelope-simple-fill', label: 'Email', value: settings.email, href: `mailto:${settings.email}` },
  { icon: 'ph:map-pin-fill', label: 'Address', value: settings.address },
  { icon: 'ph:clock-fill', label: 'Hours', value: settings.hours },
];
---

<section id="contact" class="scroll-mt-16 bg-brand-white">
  <div class="mx-auto max-w-content px-6 py-20 md:py-28">
    <div class="max-w-2xl" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Ready to get comfortable again?</h2>
      <p class="mt-4 text-lg leading-relaxed text-steel">
        Whether it's a quick repair, a seasonal tune-up, or a brand-new system, Desert Peak
        is ready to help. Reach out today and find out why Henderson trusts us to keep the
        air just right.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
      {
        details.map((d) => (
          <div class="rounded-md border border-hairline p-5">
            <Icon name={d.icon} class="h-6 w-6 text-brand-red" aria-hidden="true" />
            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-steel">{d.label}</p>
            {d.href ? (
              <a href={d.href} class="mt-1 block font-semibold text-brand-navy hover:text-brand-red">
                {d.value}
              </a>
            ) : (
              <p class="mt-1 whitespace-pre-line font-semibold text-brand-navy">{d.value}</p>
            )}
          </div>
        ))
      }
    </div>

    <div class="mt-6 rounded-lg bg-mist p-6 md:p-10" data-reveal>
      <form id="contactForm" class="grid gap-5 md:grid-cols-2" novalidate>
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="subject" value="New service request from the Desert Peak website" />
        <input type="hidden" name="from_name" value="Desert Peak website" />
        {/* Honeypot: real users leave this empty; bots fill it and get rejected. */}
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display: none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />

        <div class="flex flex-col gap-2">
          <label for="cf-name" class="text-sm font-semibold text-brand-navy">Name</label>
          <input
            id="cf-name"
            name="name"
            type="text"
            required
            autocomplete="name"
            aria-describedby="err-name"
            class="rounded-sm border border-hairline bg-brand-white px-4 py-3 text-brand-navy outline-none focus:border-brand-navy focus:ring-2 focus:ring-brand-navy/30"
          />
          <p id="err-name" role="alert" style="display: none" class="text-sm font-medium text-brand-red"></p>
        </div>
        <div class="flex flex-col gap-2">
          <label for="cf-phone" class="text-sm font-semibold text-brand-navy">Phone</label>
          <input
            id="cf-phone"
            name="phone"
            type="tel"
            required
            autocomplete="tel"
            aria-describedby="err-phone"
            class="rounded-sm border border-hairline bg-brand-white px-4 py-3 text-brand-navy outline-none focus:border-brand-navy focus:ring-2 focus:ring-brand-navy/30"
          />
          <p id="err-phone" role="alert" style="display: none" class="text-sm font-medium text-brand-red"></p>
        </div>
        <div class="flex flex-col gap-2">
          <label for="cf-email" class="text-sm font-semibold text-brand-navy">Email</label>
          <input
            id="cf-email"
            name="email"
            type="email"
            required
            autocomplete="email"
            aria-describedby="err-email"
            class="rounded-sm border border-hairline bg-brand-white px-4 py-3 text-brand-navy outline-none focus:border-brand-navy focus:ring-2 focus:ring-brand-navy/30"
          />
          <p id="err-email" role="alert" style="display: none" class="text-sm font-medium text-brand-red"></p>
        </div>
        <div class="flex flex-col gap-2">
          <label for="cf-service" class="text-sm font-semibold text-brand-navy">Service needed</label>
          <select
            id="cf-service"
            name="service"
            class="rounded-sm border border-hairline bg-brand-white px-4 py-3 text-brand-navy outline-none focus:border-brand-navy focus:ring-2 focus:ring-brand-navy/30"
          >
            {services.map((s) => <option value={s.title}>{s.title}</option>)}
            <option value="Something else">Something else</option>
          </select>
        </div>
        <div class="flex flex-col gap-2 md:col-span-2">
          <label for="cf-message" class="text-sm font-semibold text-brand-navy">
            How can we help?
          </label>
          <textarea
            id="cf-message"
            name="message"
            rows="4"
            class="rounded-sm border border-hairline bg-brand-white px-4 py-3 text-brand-navy outline-none focus:border-brand-navy focus:ring-2 focus:ring-brand-navy/30"
          ></textarea>
        </div>
        <div class="md:col-span-2">
          <button
            type="submit"
            class="inline-flex items-center justify-center gap-2 rounded-sm bg-brand-red px-6 py-3.5 text-base font-semibold text-brand-white transition-colors hover:bg-red-deep"
          >
            Schedule Service
          </button>
        </div>
      </form>
      <p
        id="contactSuccess"
        role="status"
        style="display: none"
        class="flex items-center gap-2 rounded-md bg-brand-navy px-5 py-4 font-semibold text-brand-white"
      >
        <Icon name="ph:check-circle-fill" class="h-6 w-6 text-brand-white" aria-hidden="true" />
        Thanks. Your request is in. We will call you back shortly.
      </p>
      <p
        id="contactError"
        role="alert"
        style="display: none"
        class="mt-4 flex items-center gap-2 rounded-md border border-brand-red bg-brand-white px-5 py-4 font-medium text-brand-red"
      >
        <Icon name="ph:warning-circle-fill" class="h-6 w-6 shrink-0" aria-hidden="true" />
        Something went wrong sending your request. Please call us at {settings.phone}, or try again.
      </p>
    </div>
  </div>
</section>

<script>
  // Inline validation, then a real submit to Web3Forms (no backend needed).
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const success = document.getElementById('contactSuccess');
  const errorBox = document.getElementById('contactError');
  if (form && success && errorBox) {
    const fields = ['name', 'phone', 'email'];
    const messages: Record<string, string> = {
      name: 'Please enter your name.',
      phone: 'Please enter a phone number we can reach you at.',
      email: 'Please enter a valid email address.',
    };
    const input = (id: string) => document.getElementById('cf-' + id) as HTMLInputElement;
    const errorEl = (id: string) => document.getElementById('err-' + id) as HTMLElement;

    const setError = (id: string, msg: string) => {
      const inp = input(id);
      const err = errorEl(id);
      err.textContent = msg;
      err.style.display = 'block';
      inp.setAttribute('aria-invalid', 'true');
      inp.classList.add('border-brand-red');
      inp.classList.remove('border-hairline');
    };
    const clearError = (id: string) => {
      const inp = input(id);
      const err = errorEl(id);
      err.style.display = 'none';
      inp.removeAttribute('aria-invalid');
      inp.classList.remove('border-brand-red');
      inp.classList.add('border-hairline');
    };

    fields.forEach((id) =>
      input(id).addEventListener('input', () => {
        if (input(id).validity.valid) clearError(id);
      }),
    );

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.style.display = 'none';

      let firstInvalid: HTMLInputElement | null = null;
      fields.forEach((id) => {
        if (input(id).validity.valid) {
          clearError(id);
        } else {
          setError(id, messages[id]);
          if (!firstInvalid) firstInvalid = input(id);
        }
      });
      if (firstInvalid) {
        (firstInvalid as HTMLInputElement).focus();
        return;
      }

      const label = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message || 'Submission failed');
        form.style.display = 'none';
        success.style.display = 'flex';
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch {
        errorBox.style.display = 'flex';
        submitBtn.disabled = false;
        submitBtn.textContent = label;
      }
    });
  }
</script>
